              <mxPoint x="755" y="295" />
            </Array>
            <mxPoint x="755" y="340" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="e-sc-fx" value="USB 拔出" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;html=1;endArrow=block;endFill=1;strokeColor=#666666;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="755" y="400" />
              <mxPoint x="545" y="400" />
            </Array>
            <mxPoint x="755" y="382" as="sourcePoint" />
            <mxPoint x="545" y="382" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="sc-note-inf" value="INFECTED：&#xa;病毒文件名加 [病毒禁止访问] 前缀，&#xa;FAT size=0，进入文件访问 5 级策略第 1 级" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#888888;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="240" y="395" width="280" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-note" value="说明：&#xa;• 扫描通过 Unix socket 连接 clamd 守护进程，不是 clamscan 子进程&#xa;• 终态（CLEAN/INFECTED/CANCELLED/FAILED）触发后续 U 盘状态机转换（见设备状态机图 Tab 1）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D4A72C;fontSize=10;arcSize=6;align=left;verticalAlign=top;spacing=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="760" height="55" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="系统程序升级状态机" id="d06-upgrade-state">
    <mxGraphModel dx="1000" dy="550" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="530" math="0" shadow="0">
