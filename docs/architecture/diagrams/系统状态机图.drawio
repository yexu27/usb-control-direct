        <mxCell id="up-sub" value="管理端推送升级包后触发。SHA256 校验 + 版本号必须高于当前版本。升级失败自动回滚。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
