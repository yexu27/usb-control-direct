          <mxGeometry x="280" y="298" width="190" height="42" as="geometry" />
        </mxCell>
        <mxCell id="up-restart" value="RESTARTING&#xa;重启中" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;arcSize=12;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
