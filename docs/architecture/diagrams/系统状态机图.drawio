        <mxCell id="sc-title" value="病毒扫描任务状态机" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="15" width="840" height="32" as="geometry" />
        </mxCell>
        <mxCell id="sc-sub" value="每次 U 盘挂载后由 S03 创建一个扫描任务。FIFO 调度，同一时间只运行一个扫描任务（clamd 单并发）。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="60" y="48" width="780" height="22" as="geometry" />
        </mxCell>
        <mxCell id="sc-start" value="" style="ellipse;whiteSpace=wrap;html=1;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="385" y="80" width="20" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sc-pending" value="PENDING&#xa;等待扫描（FIFO 排队）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="290" y="115" width="210" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-running" value="RUNNING&#xa;扫描中（clamd 全盘扫描）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=12;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="215" width="210" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-clean" value="CLEAN&#xa;干净" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=12;arcSize=12;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="150" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-infected" value="INFECTED&#xa;检出病毒" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D4A72C;fontSize=12;arcSize=12;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="340" width="150" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-cancelled" value="CANCELLED&#xa;已取消" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E6E6;strokeColor=#666666;fontSize=12;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="470" y="340" width="150" height="42" as="geometry" />
        </mxCell>
        <mxCell id="sc-failed" value="FAILED&#xa;扫描失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="340" width="150" height="42" as="geometry" />
        </mxCell>
        <mxCell id="e-sc-s" value="" style="endArrow=block;endFill=1;strokeColor=#333333;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="395" y="100" as="sourcePoint" />
            <mxPoint x="395" y="115" as="targetPoint" />
          </mxGeometry>
        </mxCell>
