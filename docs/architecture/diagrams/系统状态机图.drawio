        </mxCell>
        <mxCell id="up-idle" value="IDLE&#xa;空闲" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6E6E6;strokeColor=#666666;fontSize=12;arcSize=12;strokeWidth=2;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="295" y="108" width="160" height="42" as="geometry" />
        </mxCell>
        <mxCell id="up-val" value="VALIDATING&#xa;SHA256 + 版本校验" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;arcSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="280" y="200" width="190" height="42" as="geometry" />
