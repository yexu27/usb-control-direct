        <mxCell id="rules-f" parent="rules" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fontSize=11;whiteSpace=wrap;html=1;" value="日志滚动覆盖（一进一出）:&#xa;  装置整体存储 &gt; 80% → 删该类最旧 1 条&#xa;  不跨类别覆盖&#xa;  覆盖行为记录到 T11&#xa;&#xa;人工清理:&#xa;  半年以内日志禁止清理&#xa;  分批执行(500-1000条/批)&#xa;&#xa;Rust 服务运行日志:&#xa;  本地文件, 不进 T05/T06/T10&#xa;&#xa;Schema 版本: PRAGMA user_version = 1&#xa;空间回收: auto_vacuum = FULL" vertex="1">
          <mxGeometry height="216" width="330" y="24" as="geometry" />
        </mxCell>
