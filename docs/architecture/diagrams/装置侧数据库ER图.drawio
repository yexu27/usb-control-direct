        <mxCell id="legend-f" parent="legend" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=6;spacingRight=4;overflow=hidden;fontSize=11;whiteSpace=wrap;html=1;" value="橙色: 业务配置表 (T01-T04)&#xa;紫色: 系统与权限表 (T07-T09)&#xa;绿色: 日志表 (T05-T06, T10-T11)&#xa;黄色: 规则与初始化&#xa;────────────&#xa;N:1 灰色虚线: 业务关联 (非外键约束)&#xa;橙色虚线: 开关控制关系&#xa;绿色虚线: 日志覆盖关系&#xa;PK = 主键 / UK = 唯一约束" vertex="1">
          <mxGeometry height="156" width="330" y="24" as="geometry" />
        </mxCell>
