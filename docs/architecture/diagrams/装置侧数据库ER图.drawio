        <mxCell id="rules" parent="1" style="swimlane;fontStyle=1;align=center;startSize=24;fontSize=12;collapsible=0;fillColor=#FEF9E7;strokeColor=#D4AC0D;rounded=0;whiteSpace=wrap;html=1;" value="业务规则与约束" vertex="1">
