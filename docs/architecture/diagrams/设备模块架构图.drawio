        <mxCell id="note3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;数据边界&lt;br&gt;SQLite 与日志均在装置侧；管理端只保留进程内状态，不持久化业务数据。&lt;/font&gt;" vertex="1">
