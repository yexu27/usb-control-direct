        <mxCell id="note1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;font style=&quot;&quot;&gt;主业务链路&lt;br&gt;USB 外设经装置准入、扫描和 NBD 文件控制后，&lt;/font&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(0, 0, 0));&quot;&gt;通过 USB Gadget 暴露给受控主机。&lt;/span&gt;&lt;/font&gt;" vertex="1">
