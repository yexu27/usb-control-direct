        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#555555;" value="S04 NBD Server 对文件读取/写入请求执行 5 级短路判断；规则 1-4 通过 I/O error 阻断，规则 5 使用 SCSI 写保护。" vertex="1">
          <mxGeometry height="28" width="1480" x="60" y="60" as="geometry" />
        </mxCell>
        <mxCell id="req" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;arcSize=8;fontStyle=1;align=center;verticalAlign=middle;" value="受控主机文件访问请求" vertex="1">
          <mxGeometry height="48" width="310" x="545" y="105" as="geometry" />
        </mxCell>
        <mxCell id="datapath" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=11;arcSize=6;align=center;verticalAlign=middle;" value="SCSI READ(10) / WRITE(10) → f_mass_storage → /dev/nbdX → NBD Server (S04)&#xa;扇区地址 → 虚拟 exFAT 布局解析 → /mnt/usb_raw 文件路径 + 块内偏移" vertex="1">
          <mxGeometry height="55" width="520" x="440" y="180" as="geometry" />
        </mxCell>
        <mxCell id="c1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D4A72C;fontSize=12;align=center;verticalAlign=middle;" value="① 病毒标记阻断？&#xa;文件名含 [病毒禁止访问] 前缀" vertex="1">
          <mxGeometry height="90" width="290" x="555" y="295" as="geometry" />
        </mxCell>
        <mxCell id="c2" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF4CC;strokeColor=#D4A72C;fontSize=12;align=center;verticalAlign=middle;" value="② 可执行程序访问控制？&#xa;开关开启 + 文件为 dll/exe/PE/ELF&#xa;（基于文件实际格式识别）" vertex="1">
          <mxGeometry height="90" width="290" x="555" y="425" as="geometry" />
