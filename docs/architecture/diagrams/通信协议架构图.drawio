        </mxCell>
        <mxCell id="er_7_2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A7B7D0;strokeWidth=1;fontSize=10;fontStyle=0;align=center;verticalAlign=middle;" value="装置内部错误" vertex="1">
          <mxGeometry height="22" width="280" x="1930" y="1234" as="geometry" />
        </mxCell>
        <mxCell id="ext_text" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FC;strokeColor=#D7DEE8;fontSize=11;align=left;verticalAlign=top;spacing=12;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;· 0x0700-0x07FF 为装置端推送消息预留区间，当前版本无主动推送消息。&lt;br&gt;· 新增接口必须分配消息类型码、定义 Protobuf 载荷、补充权限校验与错误码。&lt;/font&gt;" vertex="1">
          <mxGeometry height="59" width="490" x="1740" y="1371" as="geometry" />
        </mxCell>
        <mxCell id="p10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#8AA0BD;strokeWidth=1.4;arcSize=3;" value="" vertex="1">
          <mxGeometry height="150" width="2220" x="41" y="1716" as="geometry" />
        </mxCell>
        <mxCell id="p10_h" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EEF3F9;strokeColor=#EEF3F9;fontColor=#1F4E9A;fontSize=14;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=14;" value="10. 关键说明" vertex="1">
          <mxGeometry height="40" width="2220" x="41" y="1716" as="geometry" />
        </mxCell>
        <mxCell id="note1_num" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFFFFF;strokeColor=#2F73D2;strokeWidth=1.5;fontColor=#2F73D2;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" value="1" vertex="1">
          <mxGeometry height="38" width="38" x="81" y="1766" as="geometry" />
        </mxCell>
        <mxCell id="note1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="协议边界&#xa;协议只服务于管理端与装置端直连管理链路，不承载受控主机 USB 文件读写链路。" vertex="1">
          <mxGeometry height="76" width="430" x="136" y="1761" as="geometry" />
        </mxCell>
        <mxCell id="note2_num" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFFFFF;strokeColor=#2F73D2;strokeWidth=1.5;fontColor=#2F73D2;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" value="2" vertex="1">
          <mxGeometry height="38" width="38" x="601" y="1766" as="geometry" />
        </mxCell>
        <mxCell id="note2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="安全边界&#xa;TLS 指纹、授权状态、session token、角色权限均由装置端校验，管理端 UI 权限不是安全边界。" vertex="1">
          <mxGeometry height="76" width="430" x="656" y="1761" as="geometry" />
        </mxCell>
        <mxCell id="note3_num" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFFFFF;strokeColor=#2F73D2;strokeWidth=1.5;fontColor=#2F73D2;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" value="3" vertex="1">
          <mxGeometry height="38" width="38" x="1121" y="1766" as="geometry" />
        </mxCell>
        <mxCell id="note3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="数据边界&#xa;管理端不保存账号、token、日志或最近 IP；协议响应中的业务数据仅用于当前进程内展示。" vertex="1">
          <mxGeometry height="76" width="430" x="1176" y="1761" as="geometry" />
        </mxCell>
        <mxCell id="note4_num" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#FFFFFF;strokeColor=#2F73D2;strokeWidth=1.5;fontColor=#2F73D2;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" value="4" vertex="1">
          <mxGeometry height="38" width="38" x="1641" y="1766" as="geometry" />
        </mxCell>
        <mxCell id="note4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#333;" value="扩展边界&#xa;新增命令需同步更新 09-api.md、proto、权限矩阵、接口测试和 E2E 协议用例。" vertex="1">
          <mxGeometry height="76" width="430" x="1696" y="1761" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
