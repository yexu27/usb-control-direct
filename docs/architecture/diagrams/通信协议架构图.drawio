        </mxCell>
        <mxCell id="er_6_2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A7B7D0;strokeWidth=1;fontSize=10;fontStyle=0;align=center;verticalAlign=middle;" value="文件格式错误" vertex="1">
          <mxGeometry height="22" width="280" x="1930" y="1212" as="geometry" />
        </mxCell>
        <mxCell id="er_7_1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A7B7D0;strokeWidth=1;fontSize=10;fontStyle=0;align=center;verticalAlign=middle;" value="INTERNAL_ERROR" vertex="1">
