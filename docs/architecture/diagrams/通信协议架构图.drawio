        </mxCell>
        <mxCell id="er_5_2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#A7B7D0;strokeWidth=1;fontSize=10;fontStyle=0;align=center;verticalAlign=middle;" value="病毒库版本逢 4 跳过" vertex="1">
