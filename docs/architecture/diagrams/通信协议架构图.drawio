        <mxCell id="code_login" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F3FF;strokeColor=#8E63CE;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.1 CMD_LOGIN（登录）0x0001&lt;br&gt;CmdLogin {&lt;br&gt;  username = &quot;admin&quot;;&lt;br&gt;  password = &quot;******&quot;;&lt;br&gt;}&lt;br&gt;RspLogin {&lt;br&gt;  success = true;&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;  role = &quot;admin&quot;;&lt;br&gt;  auth_status = &quot;authorized&quot;;&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="700" y="520" as="geometry" />
        </mxCell>
        <mxCell id="code_license" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D4A72C;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.2 CMD_UPLOAD_LICENSE（授权）0x0007&lt;br&gt;CmdUploadLicense {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;  license_data = bytes;&lt;br&gt;}&lt;br&gt;RspUploadLicense {&lt;br&gt;  success = true;&lt;br&gt;  expire_time = &quot;2027-06-01&quot;;&lt;br&gt;  error_message = &quot;&quot;;&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1025" y="520" as="geometry" />
        </mxCell>
        <mxCell id="code_logout" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D4A72C;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.3 CMD_LOGOUT（登出）0x0009&lt;br&gt;CmdLogout {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;}&lt;br&gt;响应：RSP_COMMON&lt;br&gt;&lt;br&gt;token 有效：立即失效&lt;br&gt;token 无效：返回 UNAUTHENTICATED&lt;br&gt;装置侧记录操作日志&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1350" y="520" as="geometry" />
        </mxCell>
        <mxCell id="code_whitelist" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FAF4;strokeColor=#2D8A4F;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.4 CMD_LIST_WHITELIST（白名单）0x0100&lt;br&gt;CmdListWhitelist {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;}&lt;br&gt;RspListWhitelist {&lt;br&gt;  devices = [WhitelistDevice {&lt;br&gt;    serial_number, vid, pid,&lt;br&gt;    device_name, permission,&lt;br&gt;    add_method, ...&lt;br&gt;  }];&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="700" y="755" as="geometry" />
        </mxCell>
        <mxCell id="code_filepolicy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEF8;strokeColor=#6C8EBF;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.5 CMD_GET_FILE_POLICY（文件策略）0x0200&lt;br&gt;CmdGetFilePolicy {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;}&lt;br&gt;RspFilePolicy {&lt;br&gt;  exec_control_enabled = true;&lt;br&gt;  auto_read_control_enabled = true;&lt;br&gt;  file_type_blacklist_enabled = true;&lt;br&gt;  blacklist = [...];&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1025" y="755" as="geometry" />
        </mxCell>
        <mxCell id="code_export" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F0;strokeColor=#F28E2B;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.6 CMD_EXPORT_POLICY（导出策略）0x0300&lt;br&gt;CmdExportPolicy {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;}&lt;br&gt;RspExportPolicy {&lt;br&gt;  success = true;&lt;br&gt;  policy_data = bytes;&lt;br&gt;  error_message = &quot;&quot;;&lt;br&gt;}&lt;br&gt;导出为加密 .bin 文件&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1350" y="755" as="geometry" />
        </mxCell>
        <mxCell id="code_policy" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF5F0;strokeColor=#F28E2B;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.7 CMD_IMPORT_POLICY（导入策略）0x0302&lt;br&gt;CmdImportPolicy {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;  filename = &quot;usbPolicy.bin&quot;;&lt;br&gt;  file_bytes = bytes;&lt;br&gt;}&lt;br&gt;RspCommon {&lt;br&gt;  success = true;&lt;br&gt;  error_code = &quot;&quot;;&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="700" y="990" as="geometry" />
        </mxCell>
        <mxCell id="code_logs" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FAF4;strokeColor=#2D8A4F;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.8 CMD_QUERY_LOGS（查询日志）0x0400&lt;br&gt;CmdQueryLogs {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;  log_type = &quot;usb_audit&quot;;&lt;br&gt;  page = 1;&lt;br&gt;  page_size = 20;&lt;br&gt;}&lt;br&gt;RspQueryLogs {&lt;br&gt;  total = 100;&lt;br&gt;  entries = [...];&lt;br&gt;}&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1025" y="990" as="geometry" />
        </mxCell>
        <mxCell id="code_upgrade" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBE7;strokeColor=#B85450;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.9 CMD_UPLOAD_SYSTEM_UPGRADE（升级）0x0502&lt;br&gt;CmdUploadSystemUpgrade {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;  filename = &quot;upgrade.bin&quot;;&lt;br&gt;  file_bytes = bytes;&lt;br&gt;}&lt;br&gt;失败时返回：&lt;br&gt;VERSION_TOO_LOW / FORMAT_ERROR&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1350" y="990" as="geometry" />
        </mxCell>
        <mxCell id="code_users" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8F3FF;strokeColor=#8E63CE;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.10 CMD_LIST_USERS（用户列表）0x0600&lt;br&gt;CmdListUsers {&lt;br&gt;  session_token = &quot;...&quot;;&lt;br&gt;}&lt;br&gt;RspListUsers {&lt;br&gt;  users = [UserItem {&lt;br&gt;    username, role,&lt;br&gt;    status, is_builtin,&lt;br&gt;    created_at&lt;br&gt;  }];&lt;br&gt;}&lt;br&gt;仅系统管理员可调用&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="700" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="code_common" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EEF8;strokeColor=#6C8EBF;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.11 RSP_COMMON（通用响应）0xFF00&lt;br&gt;RspCommon {&lt;br&gt;  success = false;&lt;br&gt;  error_code = &quot;PERMISSION_DENIED&quot;;&lt;br&gt;  error_message = &quot;当前角色无权限&quot;;&lt;br&gt;}&lt;br&gt;提示文本可直接展示给用户&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1025" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="code_hb" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1E5FF;strokeColor=#7B61A8;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=10;arcSize=5;fontFamily=Courier New;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;6.12 CMD_HEARTBEAT / RSP_HEARTBEAT（心跳）&lt;br&gt;CMD_HEARTBEAT (0xFF01)&lt;br&gt;RSP_HEARTBEAT (0xFF02)&lt;br&gt;Payload: empty&lt;br&gt;&lt;br&gt;每 30 秒发送一次&lt;br&gt;连续 3 次无响应：&lt;br&gt;管理端标记断连，页面保留，动作失败提示&lt;/font&gt;" vertex="1">
          <mxGeometry height="210" width="300" x="1350" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="code_note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#C9B037;strokeWidth=1.2;fontSize=10;align=left;verticalAlign=top;spacing=12;arcSize=3;" value="&lt;font style=&quot;font-size: 12px;&quot;&gt;&lt;b style=&quot;&quot;&gt;其他消息指令（完整 Protobuf 载荷定义详见《09-私有协议与接口设计》）&lt;/b&gt;&lt;br&gt;&lt;br&gt;连接与授权：CMD_AUTH_STATUS_QUERY(0x0003)、CMD_GET_MACHINE_CODE(0x0005)&lt;br&gt;白名单管理：CMD_GET_CONNECTED_DEVICES(0x0102)、CMD_ADD_WHITELIST(0x0104)、CMD_REMOVE_WHITELIST(0x0105)、CMD_UPDATE_WHITELIST(0x0106)&lt;br&gt;文件访问控制：CMD_UPDATE_FILE_POLICY_SWITCH(0x0202)、CMD_ADD_BLACKLIST_EXTENSION(0x0203)、CMD_REMOVE_BLACKLIST_EXTENSION(0x0204)&lt;br&gt;日志管理：CMD_EXPORT_LOGS(0x0402)、CMD_DELETE_LOGS(0x0404)&lt;br&gt;系统管理：CMD_GET_SYSTEM_INFO(0x0500)、CMD_UPLOAD_VIRUSDB_UPGRADE(0x0503)、CMD_UPDATE_DEVICE_DESC(0x0504)&lt;br&gt;用户管理：CMD_CREATE_USER(0x0602)、CMD_DELETE_USER(0x0603)、CMD_RESET_PASSWORD(0x0604)、CMD_CHANGE_PASSWORD(0x0605)&lt;/font&gt;" vertex="1">
          <mxGeometry height="180" width="950" x="700" y="1460" as="geometry" />
        </mxCell>
        <mxCell id="sec_text" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F7F9FC;strokeColor=#D7DEE8;fontSize=11;align=left;verticalAlign=top;spacing=12;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;· 传输协议：TCP + TLS&lt;br&gt;· 管理端校验装置证书 SHA256 指纹&lt;br&gt;· 指纹不一致：拒绝连接并提示版本不兼容&lt;br&gt;· 载荷序列化：Protocol Buffers&lt;br&gt;· 单帧载荷最大：128MB&lt;br&gt;· session_token 仅管理端进程内保存&lt;br&gt;· 所有登录后接口由装置端校验授权、token 和 role&lt;/font&gt;" vertex="1">
          <mxGeometry height="140" width="490" x="1740" y="797" as="geometry" />
        </mxCell>
        <mxCell id="er_h1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#E8EEF8;strokeColor=#A7B7D0;strokeWidth=1;fontSize=10;fontStyle=1;align=center;verticalAlign=middle;" value="错误码" vertex="1">
