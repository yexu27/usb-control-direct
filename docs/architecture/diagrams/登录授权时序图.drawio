        <mxCell id="p3" value="S10 API 网关" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9C6ADE;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="870" y="120" width="140" height="55" as="geometry"/></mxCell>
        <mxCell id="life3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="175" as="sourcePoint"/><mxPoint x="940" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p4" value="S08 用户与会话" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9C6ADE;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1080" y="120" width="140" height="55" as="geometry"/></mxCell>
        <mxCell id="life4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1150" y="175" as="sourcePoint"/><mxPoint x="1150" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p5" value="S09 授权与维护" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9C6ADE;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1290" y="120" width="140" height="55" as="geometry"/></mxCell>
        <mxCell id="life5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1360" y="175" as="sourcePoint"/><mxPoint x="1360" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p6" value="S07 日志审计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F7F7;strokeColor=#00A3A3;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="1480" y="120" width="130" height="55" as="geometry"/></mxCell>
        <mxCell id="life6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1545" y="175" as="sourcePoint"/><mxPoint x="1545" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="phase1" value="── 登录阶段 ──" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#1F77B4;" vertex="1" parent="1"><mxGeometry x="40" y="200" width="150" height="25" as="geometry"/></mxCell>
        <mxCell id="m1" value="输入 IP / 用户名 / 密码" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="240" as="sourcePoint"/><mxPoint x="330" y="240" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m2" value="connect(ip)，不记住 IP" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="330" y="290" as="sourcePoint"/><mxPoint x="680" y="290" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m3" value="TCP/TLS 握手 + 证书指纹校验" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="340" as="sourcePoint"/><mxPoint x="940" y="340" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m4" value="CMD_LOGIN(0x0001, username, password)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="400" as="sourcePoint"/><mxPoint x="940" y="400" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m5" value="校验账号、锁定状态、密码" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="450" as="sourcePoint"/><mxPoint x="1150" y="450" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m6" value="RSP_LOGIN(0x0002, token/role/auth_status)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1150" y="510" as="sourcePoint"/><mxPoint x="940" y="510" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="phase2" value="── 授权检查阶段 ──" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#1F77B4;" vertex="1" parent="1"><mxGeometry x="40" y="545" width="180" height="25" as="geometry"/></mxCell>
        <mxCell id="m7" value="检查 auth_status" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="580" as="sourcePoint"/><mxPoint x="1360" y="580" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m8" value="返回授权状态" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1360" y="630" as="sourcePoint"/><mxPoint x="940" y="630" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m9" value="授权分支结果 + RSP_LOGIN" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="680" as="sourcePoint"/><mxPoint x="680" y="680" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m9b" value="设置全局状态：已连接 + 角色" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="720" as="sourcePoint"/><mxPoint x="505" y="720" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m10" value="跳转授权页或角色默认页" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="505" y="760" as="sourcePoint"/><mxPoint x="330" y="760" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="phase3" value="── 登出阶段 ──" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=1;fontColor=#1F77B4;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="150" height="25" as="geometry"/></mxCell>
        <mxCell id="m11" value="点击登出" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="840" as="sourcePoint"/><mxPoint x="330" y="840" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m12" value="发送登出请求" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="330" y="880" as="sourcePoint"/><mxPoint x="680" y="880" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m13" value="CMD_LOGOUT(0x0009, session_token)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="920" as="sourcePoint"/><mxPoint x="940" y="920" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m14" value="失效当前 session token" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#1F77B4;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="960" as="sourcePoint"/><mxPoint x="1150" y="960" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m15" value="写入操作日志（用户登出）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1150" y="1000" as="sourcePoint"/><mxPoint x="1545" y="1000" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m16" value="RSP_COMMON(0xFF00)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="1040" as="sourcePoint"/><mxPoint x="680" y="1040" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m17" value="清空会话状态和页面状态" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="680" y="1075" as="sourcePoint"/><mxPoint x="505" y="1075" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m18" value="返回登录页" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;dashed=1;strokeColor=#888888;fontSize=11;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="505" y="1105" as="sourcePoint"/><mxPoint x="330" y="1105" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="branch" value="分支规则&#xa;1. 未授权 + 任一有效账号：进入独立授权页&#xa;2. 授权导入成功：返回登录页重新登录&#xa;3. 已授权：C04 按角色拉取装置数据，进入默认页&#xa;4. 主系统内授权管理：仅系统管理员&#xa;5. 登出异常：管理端与装置已断开时仍清空本地状态返回登录页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D4A72C;fontSize=12;arcSize=6;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="60" y="1170" width="460" height="145" as="geometry"/></mxCell>
        <mxCell id="boundary" value="管理端边界&#xa;不落盘保存账号、token、最近 IP&#xa;断连保留页面快照，下发动作失败提示&#xa;主动登出调用 CMD_LOGOUT 失效 token&#xa;进程退出后必须重新登录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#F28E2B;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="560" y="1170" width="350" height="145" as="geometry"/></mxCell>
        <mxCell id="test" value="自动化测试&#xa;三角色未授权进入授权页&#xa;5 次失败锁定 5 分钟&#xa;授权成功后必须重新登录&#xa;主动登出 token 失效&#xa;断连时登出仍清空本地状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E8FF;strokeColor=#9C6ADE;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="950" y="1170" width="350" height="145" as="geometry"/></mxCell>
        <mxCell id="key-notes" value="# 关键说明&#xa;1. 登录阶段从左到右完成连接、TLS 握手、CMD_LOGIN 鉴权；回包统一使用虚线。&#xa;2. 授权检查阶段：装置端根据 auth_status 决定进入独立授权页还是角色默认页。&#xa;3. 登出阶段：CMD_LOGOUT(0x0009) 使装置侧 token 失效，S07 记录操作日志，管理端清空进程内状态返回登录页。&#xa;4. 异常登出：管理端与装置已断开时，管理端仍需清空本地状态返回登录页，装置侧会话按超时规则失效。&#xa;5. S08/S09/S07 的数据读写均通过 S11 数据存储适配层访问 SQLite，时序图省略 S11 以聚焦业务流程。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#D4A72C;fontSize=12;arcSize=6;align=left;verticalAlign=top;spacing=8;" vertex="1" parent="1"><mxGeometry x="60" y="1340" width="1530" height="145" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
