<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" version="21.0.0">
  <diagram name="登录授权时序图" id="d05-auth-sequence">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1650" pageHeight="1600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="登录授权与登出时序图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="30" y="20" width="1590" height="36" as="geometry"/></mxCell>
        <mxCell id="subtitle" value="账号、会话、授权状态均由装置侧校验；未授权独立授权页三类有效账号均可进入；登出由装置侧失效 token。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="60" y="60" width="1530" height="28" as="geometry"/></mxCell>
        <mxCell id="p0" value="用户" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#F28E2B;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="160" height="55" as="geometry"/></mxCell>
        <mxCell id="life0" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="120" y="175" as="sourcePoint"/><mxPoint x="120" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p1" value="C01 页面与路由" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#F28E2B;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="260" y="120" width="140" height="55" as="geometry"/></mxCell>
        <mxCell id="life1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="330" y="175" as="sourcePoint"/><mxPoint x="330" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p1b" value="C02 会话状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#F28E2B;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="440" y="120" width="130" height="55" as="geometry"/></mxCell>
        <mxCell id="life1b" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;dashed=1;strokeColor=#AAAAAA;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="505" y="175" as="sourcePoint"/><mxPoint x="505" y="1130" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="p2" value="C03 通信客户端" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#F28E2B;fontSize=12;arcSize=8;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="610" y="120" width="140" height="55" as="geometry"/></mxCell>
