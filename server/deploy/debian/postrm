#!/usr/bin/env bash
set -euo pipefail

action="${1:-remove}"

if [ "$action" = "remove" ] || [ "$action" = "purge" ]; then
  rm -f /etc/systemd/system/usb-control.service
  rm -f /etc/udev/rules.d/99-usb-control.rules
  rm -f /usr/local/bin/usb-control-otg-init.sh
  rm -rf /opt/usb-control

  if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload || true
  fi
  if command -v udevadm >/dev/null 2>&1; then
    udevadm control --reload-rules || true
  fi
fi

if [ "$action" = "purge" ]; then
  rm -rf /etc/usb-control
fi

echo "usb-control postrm: preserved /var/lib/usb-control"
exit 0
